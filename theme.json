{
	"$schema": "https://schemas.wp.org/wp/6.7/theme.json",
	"version": 3,
    "settings": {
        "layout": {
            "contentSize": "100vw",
            "wideSize": "100vh"
        },
        "spacing": {
            "blockGap": "1rem"
        }
    },
    "styles": {
        "color": {
            "background": "#ffffff",
            "text": "#333333"
        },
        "elements": {
            "link": {
                "color": {
                    "text": "#0073aa"
                }
            }
        },
        "spacing": {
            "padding": {
                "top": "0",
                "bottom": "0"
            }
        },
       	"blocks": {
   			"core/query-pagination-next": {
				"color": {
					"text": "var:preset|color|accent-4"
				},
				"elements": {
					"link": {
						"color": {
							"text": "var:preset|color|accent-4"
						},
						"typography": {
							"textDecoration": "none"
						},
						":hover": {
							"typography": {
								"textDecoration": "underline"
							}
						}
					}
				},
				"typography": {
					"fontSize": "var:preset|font-size|small"
				},
				"spacing": {
					"margin": {
						"top": "5px",
						"bottom": "0px"
					}
				}
			}
        }
    },

}